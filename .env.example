# Local Docker Compose database container
POSTGRES_DB=fintech
POSTGRES_USER=fintech
POSTGRES_PASSWORD=change-me

# Production app envs (split from a postgres:// URI)
# Example:
# postgres://db_user:db_password@db.prisma.io:5432/postgres?sslmode=require
DB_HOST=db.prisma.io
DB_PORT=5432
DB_NAME=postgres
DB_USERNAME=db_user
DB_PASSWORD=db_password
DB_SSL_MODE=require

APP_JWT_SECRET=replace-with-a-long-random-secret
